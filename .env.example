# Copy to .env.local for local development
# The frontend reads NEXT_PUBLIC_* variables at build time.

# Deployed BOV program address on Solana devnet.
# Default (built-in fallback): 6jkfCwYGm33xFqBfajHHWxcnG1YJzm2Jd7cME2jUNaaf
# Override only if you deploy your own instance via SOLANA_PLAYGROUND_DEPLOY.md
NEXT_PUBLIC_BOV_PROGRAM_ID=6jkfCwYGm33xFqBfajHHWxcnG1YJzm2Jd7cME2jUNaaf

# Solana RPC endpoint (default: public devnet — sufficient for demo)
# For production use a private RPC (Helius, QuickNode, etc.)
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
