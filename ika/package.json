{
	"name": "ika-monorepo",
	"private": true,
	"license": "BSD-3-Clause-Clear",
	"scripts": {
		"test": "turbo run test",
		"test:dev": "turbo run test -- --run",
		"sdk": "turbo --filter ./sdk/typescript",
		"changeset-version": "pnpm changeset version && pnpm --filter @ika-io/ika codegen:version",
		"prettier:check": "prettier -c --ignore-unknown .",
		"prettier:fix": "prettier -w --ignore-unknown .",
		"prettier:fix:watch": "onchange '**' -i -f add -f change -j 5 -- prettier -w --ignore-unknown {{file}}",
		"prettier:fix-move": "npx prettier-move -c contracts/**/*.move --write",
		"eslint:check": "eslint --max-warnings=0 .",
		"eslint:fix": "pnpm run eslint:check --fix",
		"lint": "pnpm run eslint:check && pnpm run prettier:check",
		"lint:fix": "pnpm run eslint:fix && pnpm run prettier:fix"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"unrs-resolver"
		],
		"overrides": {
			"node-notifier": "10.0.0",
			"async": "3.2.2",
			"nth-check": "2.0.1",
			"yaml@<2.2.2": ">=2.2.2",
			"semver@<7.5.2": ">=7.5.2",
			"postcss@<8.4.31": ">=8.4.31",
			"dompurify@>=3.0.0 <3.1.3": ">=3.1.3"
		}
	},
	"engines": {
		"pnpm": ">=10.0.0"
	},
	"manypkg": {
		"ignoredRules": [
			"INTERNAL_MISMATCH",
			"ROOT_HAS_DEV_DEPENDENCIES"
		]
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.8",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@manypkg/cli": "^0.25.1",
		"@mysten/prettier-plugin-move": "^0.3.5",
		"concurrently": "^9.2.1",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import-x": "^4.16.1",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-require-extensions": "^0.1.3",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"turbo": "^2.8.12",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1"
	},
	"packageManager": "pnpm@10.30.3"
}
